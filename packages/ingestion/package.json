{
  "name": "@opencodehub/ingestion",
  "version": "0.1.0",
  "description": "OpenCodeHub — indexing pipeline (12-phase DAG, tree-sitter, language providers)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "node --test './dist/**/*.test.js'",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "12.1.0",
    "@aws-sdk/client-bedrock-runtime": "3.1035.0",
    "@cyclonedx/cyclonedx-library": "10.0.0",
    "@graphty/algorithms": "1.7.1",
    "@iarna/toml": "2.2.5",
    "@opencodehub/analysis": "workspace:*",
    "@opencodehub/core-types": "workspace:*",
    "@opencodehub/embedder": "workspace:*",
    "@opencodehub/scip-ingest": "workspace:*",
    "@opencodehub/storage": "workspace:*",
    "@opencodehub/summarizer": "workspace:*",
    "fast-xml-parser": "5.7.1",
    "graphology": "0.26.0",
    "graphology-dag": "0.4.1",
    "piscina": "5.1.4",
    "snyk-nodejs-lockfile-parser": "2.7.0",
    "spdx-correct": "^3.2.0",
    "tree-sitter": "0.25.0",
    "tree-sitter-c": "0.24.1",
    "tree-sitter-c-sharp": "0.23.5",
    "tree-sitter-cpp": "0.23.4",
    "tree-sitter-dart": "git+https://github.com/UserNobody14/tree-sitter-dart.git#0fc19c3a57b1109802af41d2b8f60d8835c5da3a",
    "tree-sitter-go": "0.25.0",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-kotlin": "0.3.8",
    "tree-sitter-php": "0.24.2",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-ruby": "0.23.1",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-swift": "0.7.1",
    "tree-sitter-typescript": "0.23.2",
    "web-tree-sitter": "0.26.8",
    "write-file-atomic": "7.0.1"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@types/spdx-correct": "^3.1.3",
    "@types/write-file-atomic": "4.0.3",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "ajv-formats-draft2019": "1.6.1",
    "typescript": "6.0.3"
  },
  "optionalDependencies": {
    "ts-morph": "^25.0.1"
  }
}
