{
  "name": "@opencodehub/embedder",
  "version": "0.1.0",
  "description": "OpenCodeHub — ONNX-based deterministic text embedder (Arctic Embed XS)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "node --test './dist/**/*.test.js'",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@huggingface/tokenizers": "0.1.3",
    "@opencodehub/core-types": "workspace:*",
    "onnxruntime-node": "1.24.3"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "typescript": "6.0.3"
  }
}
