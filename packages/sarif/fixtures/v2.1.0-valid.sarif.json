  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "semgrep",
          "version": "1.50.0",
          "informationUri": "https://semgrep.dev",
          "rules": [
            {
              "id": "javascript.lang.security.audit.xss.direct-response-write.direct-response-write",
              "name": "direct-response-write",
              "shortDescription": {
                "text": "Reflected XSS via direct res.write"
