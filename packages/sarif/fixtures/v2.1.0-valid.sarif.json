          "fingerprints": { "matchBasedId/v1": "a73d2c9" },
          "properties": {
            "opencodehub.blastRadius": 7,
            "opencodehub.cochangeScore": 0.81
          }
        }
      ]
    },
    {
      "tool": {
        "driver": {
          "name": "gitleaks",
          "semanticVersion": "8.18.0",
          "informationUri": "https://github.com/gitleaks/gitleaks"
