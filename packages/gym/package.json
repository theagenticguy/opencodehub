{
  "name": "@opencodehub/gym",
  "version": "0.1.0",
  "description": "OpenCodeHub — SCIP-indexer evaluation harness (freeze/replay manifests, P/R/F1 metrics, three-layer regression gates)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "codehub-gym": "./dist/cli.js"
  },
  "files": [
    "dist",
    "corpus",
    "baselines",
    "reference"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "node --test './dist/**/*.test.js'",
    "clean": "rm -rf dist *.tsbuildinfo",
    "codehub-gym": "node ./dist/cli.js"
  },
  "dependencies": {
    "@opencodehub/scip-ingest": "workspace:*",
    "@opencodehub/storage": "workspace:*",
    "commander": "14.0.3",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "typescript": "6.0.3"
  }
}
