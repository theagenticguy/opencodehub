{
  "name": "@opencodehub/pack",
  "version": "0.1.0",
  "description": "OpenCodeHub — deterministic M5 9-item code-pack BOM",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "node --test './dist/**/*.test.js'",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@opencodehub/analysis": "workspace:*",
    "@opencodehub/core-types": "workspace:*",
    "@opencodehub/ingestion": "workspace:*",
    "@opencodehub/storage": "workspace:*",
    "chonkie": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "typescript": "6.0.3"
  }
}
