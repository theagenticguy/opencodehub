{
  "name": "opencodehub-monorepo",
  "version": "0.8.6",
  "private": true,
  "description": "OpenCodeHub — Apache-2.0 code intelligence graph + MCP server for AI coding agents",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "pnpm -r run clean",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "banned-strings": "bash scripts/check-banned-strings.sh",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run banned-strings",
    "commit": "cz"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/node": "25.9.3",
    "commitizen": "4.3.2",
    "cz-conventional-changelog": "3.3.0",
    "lefthook": "2.1.9",
    "license-checker-rseidelsohn": "4.4.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
